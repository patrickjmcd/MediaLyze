# App ports
APP_PORT=8008

# Public URL of your app (HTTPS in production)
APP_URL=https://medialyze.example.com
LOCAL_APP_URL=http://localhost:8008

# Host directories mounted into the container
DATA_HOST_DIR=./data
LIBRARY_HOST_DIR=/path/to/your/library

# Optional image label/version when building locally
APP_VERSION=dev
