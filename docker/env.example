# HTTP port exposed on the host; container listens internally on 8080.
# Access MediaLyze via http://<host>:<HOST_PORT> unless you terminate HTTPS in a reverse proxy.
HOST_PORT=8080

# Maximum number of libraries scanned in parallel
SCAN_RUNTIME_WORKER_COUNT=4

# Optional container/dev process timezone for logs and local-time rendering
TZ=Europe/Berlin

# Writable config directory on the host
CONFIG_HOST_DIR=./config

# Read-only media root on the host
MEDIA_HOST_DIR=/path/to/your/media

# Optional: run the app with a specific user/group for NAS or shared-folder permissions.
# Leave both empty to keep the default root runtime user.
# PUID=1000
# PGID=1000

# SMB/CIFS example, recommended approach:
# Mount the share on the host first and then point MEDIA_HOST_DIR to that mount.
# Examples:
# MEDIA_HOST_DIR=/mnt/media
# MEDIA_HOST_DIR=/Volumes/media
#
# If you prefer a Docker-managed CIFS volume, a compose snippet like this is the
# safer variant of the example, because it uses the local volume driver and
# pins SMB protocol details explicitly:
#
# services:
#   medialyze:
#     volumes:
#       - nas_share:/media:ro
#
# volumes:
#   nas_share:
#     driver: local
#     driver_opts:
#       type: cifs
#       o: "addr=my-nas,username=myuser,password=mypassword,vers=3.0,ro,file_mode=0444,dir_mode=0555"
#       device: "//my-nas/share"
#
# Prefer credentials files or Docker secrets over plain-text passwords when possible.

# Optional image label/version when building locally
APP_VERSION=dev
